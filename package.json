{
	"name": "obsidian-apple-books-highlights-plugin",
	"version": "1.8.1",
	"description": "Import highlights and notes from your Apple Books to Obsidian",
	"main": "main.js",
	"scripts": {
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run copy-assets",
		"check": "oxlint --config ./.oxlintrc.json",
		"copy-assets": "cp manifest.json dist/manifest.json && cp styles.css dist/styles.css",
		"coverage": "vitest run --coverage",
		"dev": "node esbuild.config.mjs",
		"docs:build": "vitepress build docs",
		"docs:dev": "vitepress dev docs --port 3000",
		"docs:preview": "vitepress preview docs",
		"fmt": "oxfmt --config ./.oxfmtrc.json",
		"lint": "npm run check && npm run fmt",
		"lint:ci": "npm run check -- --format=stylish",
		"lint:staged": "oxfmt --config ./.oxfmtrc.json --no-error-on-unmatched-pattern",
		"postinstall": "npm run setup:git-hooks",
		"setup:git-hooks": "git config core.hooksPath .git-hooks",
		"test": "vitest --run",
		"version": "node versioning.mjs"
	},
	"author": "bandantonio",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bandantonio/obsidian-apple-books-highlights-plugin.git"
	},
	"license": "MIT",
	"keywords": [
		"apple",
		"applebooks",
		"books",
		"highlights",
		"iBooks",
		"importer",
		"notes",
		"obsidian",
		"plugin"
	],
	"engines": {
		"node": ">=24.0.0",
		"npm": ">=11.0.0"
	},
	"dependencies": {
		"dayjs": "^1.11.13",
		"handlebars": "^4.7.8"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24.3.0",
		"@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.2.0",
		"esbuild": "0.27.7",
		"obsidian": "latest",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"tslib": "2.8.1",
		"typescript": "5.9.2",
		"vitepress": "^2.0.0-alpha.17",
		"vitest": "^4.1.5"
	}
}